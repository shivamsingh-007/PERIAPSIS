# Database
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic_dev
POSTGRES_DB=agentic_loop
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://agentic:agentic_dev@localhost:5432/agentic_loop

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=your_public_key
LANGFUSE_SECRET_KEY=your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# LLM Provider (9router OpenAI-compatible proxy or direct OpenAI)
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key
LLM_BASE_URL=http://localhost:20128/v1
LLM_MODEL=gpt-4o-mini

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Security
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Governance
DEFAULT_RISK_TIER=low
MAX_ITERATIONS=12
MAX_COST_USD=2.50
MAX_RUNTIME_SECONDS=180
